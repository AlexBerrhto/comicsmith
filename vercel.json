{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/llm.js": { "maxDuration": 30 },
    "api/generate.js": { "maxDuration": 60 }
  },
  "routes": [
    { "src": "/api/llm", "dest": "/api/llm.js" },
    { "src": "/api/generate", "dest": "/api/generate.js" },
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/(.*)\\.js", "dest": "/$1.js" },
    { "src": "/(.*)\\.css", "dest": "/$1.css" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}